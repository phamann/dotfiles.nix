default_mode "normal"

copy_command "pbcopy"

keybinds {
    normal {
        bind "Alt T" { NewTab; }
    }
}

plugins {
    tab-bar { path "tab-bar"; }
    status-bar { path "status-bar"; }
    strider { path "strider"; }
    compact-bar { path "compact-bar"; }
    session-manager { path "session-manager"; }
}

// Choose what to do when zellij receives SIGTERM, SIGINT, SIGQUIT or SIGHUP
// eg. when terminal window with an active zellij session is closed
// Options:
//   - detach (Default)
//   - quit
//
// on_force_close "quit"

simplified_ui true
pane_frames false
default_layout "@layout@"

ui {
    pane_frames {
        hide_session_name true
    }
}

// Active theme. The "stylix" theme file is written to
// ~/.config/zellij/themes/stylix.kdl by Stylix (modules/theme/default.nix
// sets stylix.base16Scheme; modules/zellij sets stylix.targets.zellij.enable).
// The name stays "stylix" regardless of which base24 scheme is active.
theme "stylix"

copy_on_select false

env {
 TERM "alacritty"
}
